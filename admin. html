<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Panel</title>

<style>
body{
    background:#0d1117;
    color:white;
    font-family:Arial,sans-serif;
    padding:20px;
}

.container{
    max-width:500px;
    margin:auto;
    background:#161b22;
    padding:20px;
    border-radius:10px;
}

h1{
    color:#22c55e;
    text-align:center;
}

input,select{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:none;
    border-radius:6px;
}

button{
    width:100%;
    padding:14px;
    background:#22c55e;
    color:white;
    border:none;
    border-radius:6px;
    font-size:18px;
    cursor:pointer;
}
</style>
</head>

<body>

<div class="container">

<h1>🔐 Admin Panel</h1>

<input type="text" placeholder="Match Name">

<input type="text" placeholder="Date">

<select>
<option>✅ WON</option>
<option>❌ LOST</option>
</select>

<button>Save Result</button>

</div>

</body>
</html>